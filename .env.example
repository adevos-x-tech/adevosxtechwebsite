# ==========================================================
# ADEVOS-X BACKEND — Environment Variables
# Copy this file to ".env" and fill in real values.
# NEVER commit the real ".env" file to GitHub.
# ==========================================================

# ---------- CORE ----------
PORT=5000
NODE_ENV=development
# Comma-separated list of origins allowed to call this API from a DIFFERENT
# domain (e.g. if you later split the frontend out again, or test with an
# external tool). Not required for normal use, since public.html/admin.html
# are now served by this SAME server (same-origin = no CORS needed).
FRONTEND_URLS=http://localhost:5000

# ---------- DATABASE ----------
# MongoDB Atlas connection string (Sector: everywhere)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/adevosx?retryWrites=true&w=majority

# ---------- AUTH / JWT ----------
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# ---------- ADMIN LOGIN (username/password, Sector 24) ----------
ADMIN_USERNAME=admin
# Generate this with: npm run hash-password
ADMIN_PASSWORD_HASH=
# Optional 2FA (TOTP) — leave blank to disable. Generate with: npm run generate-2fa
ADMIN_2FA_SECRET=

# ---------- GOOGLE OAUTH (Sector 1) ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ---------- GITHUB OAUTH (Sector 1) ----------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/github/callback

# ---------- CLOUDINARY (Sector 2 — profile pictures / uploads) ----------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---------- PAYSTACK (Sector 14) ----------
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=

# ---------- HEROKU (Sector 12) ----------
HEROKU_API_KEY=
HEROKU_TEAM_NAME=

# ---------- PTERODACTYL PANEL (Sector 13) ----------
PTERODACTYL_PANEL_URL=https://panel.example.com
PTERODACTYL_API_KEY=
PTERODACTYL_EGG_ID=
PTERODACTYL_NEST_ID=
PTERODACTYL_DEFAULT_USER_ID=

# ---------- EMAIL — Resend or SMTP (Sector 23) ----------
RESEND_API_KEY=
EMAIL_FROM=Adevos-X <no-reply@adevosx.site>
# Alternative: Gmail SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
